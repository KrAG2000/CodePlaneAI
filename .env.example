PORT=3000
LOG_LEVEL=info
API_TRIGGER_TOKEN=change-me

# Target repository.
LOCAL_REPO_PATH=/home/life-workstation/Personal_Projects/CodePlaneAI
GITHUB_OWNER=KrAG2000
GITHUB_REPO=CodePlaneAI
GITHUB_BASE_BRANCH=main
GITHUB_REMOTE=origin

# You asked to skip PR creation for now, but allow push.
ENABLE_GITHUB_PR=false
ENABLE_GIT_PUSH=true
AUTO_COMMIT_ON_AGENT_RESULT=true
REQUIRE_CLEAN_WORKTREE=false

# Empty means validation is skipped for now.
VALIDATION_COMMANDS=

# Optional. Comma-separated glob rules.
PROTECTED_PATHS=infra/**,db/migrations/**,src/billing/**

# Slack incoming webhook is for sending status messages into Slack.
SLACK_INCOMING_WEBHOOK_URL=

# Slack Events API / slash command request verification.
SLACK_SIGNING_SECRET=

# Legacy Slack verification token fallback. Optional.
SLACK_VERIFICATION_TOKEN=

# Local file handoff for VS Code Codex.
CODEX_HANDOFF_DIR=.data/handoffs

# Direct Codex agent trigger. Turn this on after Slack event delivery is confirmed.
ENABLE_CODEX_AUTO_RUN=false
CODEX_COMMAND=codex
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=never
