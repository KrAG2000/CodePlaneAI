PORT=3000
LOG_LEVEL=info
API_TRIGGER_TOKEN=change-me
AI_CONFIG_DIR=config/ai-models
TRIAGE_MODEL_ID=openai-gpt-5.4-mini
TRIAGE_FALLBACK_MODEL_IDS=anthropic-claude-sonnet-4-5,google-gemini-2.5-flash,groq-llama-3.3-70b-versatile

# Provider keys are read by model config files in config/ai-models.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Target repository.
LOCAL_REPO_PATH=/home/life-workstation/Personal_Projects/CodePlaneAI
GITHUB_OWNER=<GITHUB_OWNER>
GITHUB_REPO=<REPOSITORY_NAME>
GITHUB_BASE_BRANCH=<BASE_BRANCH>
GITHUB_REMOTE=<REMOTE_NAME>

# You asked to skip PR creation for now, but allow push. [TWEAK AS NEEDED]
ENABLE_GITHUB_PR=false
ENABLE_GIT_PUSH=true
AUTO_COMMIT_ON_AGENT_RESULT=true
REQUIRE_CLEAN_WORKTREE=false

# Empty means validation is skipped for now.
VALIDATION_COMMANDS=

# Optional. Comma-separated glob rules.
PROTECTED_PATHS=infra/**,db/migrations/**,src/billing/**

# Slack incoming webhook is for sending status messages into Slack.
SLACK_INCOMING_WEBHOOK_URL=

# Slack Events API / slash command request verification.
SLACK_SIGNING_SECRET=

# Legacy Slack verification token fallback. Optional.
SLACK_VERIFICATION_TOKEN=

# Local file handoff for VS Code Codex.
CODEX_HANDOFF_DIR=.data/handoffs

# Automatic agent execution.
ENABLE_AGENT_AUTO_RUN=false
AGENT_PROVIDER=codex [Working on handling multiple providers here, but for now this is a single value.]
AGENT_COMMAND=codex [Working on handling multiple providers here, but for now this is a single value.]
AGENT_MODEL=
AGENT_TIMEOUT_MS=1800000

# Legacy compatibility toggle still supported.
ENABLE_CODEX_AUTO_RUN=false
CODEX_COMMAND=codex
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=never
